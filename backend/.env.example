# Vision backend environment variables
# Copy to backend/.env for local development. Production values live in Railway.

# ── Database ──────────────────────────────────────────────────────────────
# Local default points at the docker-compose Postgres on :5432
DATABASE_URL=postgresql://vision:vision@localhost:5432/vision

# ── Auth ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# The app refuses to boot in production if this stays at the default.
JWT_SECRET=changeme-in-production
JWT_ALGORITHM=HS256
# 7 days; will drop to 15 in Tier 3 hardening
JWT_EXPIRE_MINUTES=10080

# ── Media storage ─────────────────────────────────────────────────────────
# "local" writes to LOCAL_STORAGE_DIR for offline dev / CI.
# "s3" requires the AWS_* and S3_* settings below.
STORAGE_BACKEND=local
LOCAL_STORAGE_DIR=.local-storage

# Required when STORAGE_BACKEND=s3
# Inline trailing comments (after the `=`) are NOT stripped by python-dotenv
# and pollute string values — keep comments on their own line.
AWS_REGION=
S3_BUCKET=
# e.g. d1234abcd.cloudfront.net (no scheme, no path)
CLOUDFRONT_DOMAIN=
# Leave AWS_* unset locally; in prod they come from Railway env / boto3 creds.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Upload limits ─────────────────────────────────────────────────────────
# 10 MB
MAX_IMAGE_SIZE=10485760
# 100 MB
MAX_VIDEO_SIZE=104857600

# ── CORS (production only — comma-separated) ──────────────────────────────
# Leave unset locally; the dev defaults already allow http://localhost:3000.
# CORS_ORIGINS=https://vision.example.com,https://staging.vision.example.com
# A single regex OR'd with CORS_ORIGINS. Defaults to ^https?://localhost:\d+$
# so several frontends (worktrees, alternate ports, `next dev --experimental-https`)
# can hit one backend without bouncing it. Set to empty to disable in prod;
# override for a stricter pattern if you want.
# CORS_ORIGIN_REGEX=^https?://localhost:\d+$

# ── Rate limiting ─────────────────────────────────────────────────────────
# Per-endpoint slowapi limits (e.g. 5/min on /login, 10/hr on /register) — no
# global floor. Useful in prod; annoying during local owner self-test when the
# same tester is iterating on register/sign-in. Set to false to silence them all.
# RATE_LIMIT_ENABLED=true

# ── Cookie auth ───────────────────────────────────────────────────────────
# Default (dev): SameSite=lax, Secure=false — works for localhost:3000 ↔ :8000.
# In prod, frontend (Vercel) and backend (Railway) live on different
# registrable domains, so the browser treats them as cross-site. Set:
#   COOKIE_SECURE=true
#   COOKIE_SAMESITE=none
# COOKIE_DOMAIN is normally left empty (host-only cookie); only set it if you
# need to share a session across subdomains of a single domain.
# COOKIE_SECURE=true
# COOKIE_SAMESITE=none
# COOKIE_DOMAIN=

# ── Error tracking (optional) ─────────────────────────────────────────────
# Set SENTRY_DSN to enable Sentry. Leave empty to skip — the SDK only
# initialises when DSN is non-empty, so unset = no overhead, no PII leak.
# SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>
# SENTRY_ENVIRONMENT=production    # or staging / preview
# SENTRY_TRACES_SAMPLE_RATE=0.0    # 0.0 disables performance tracing

# ── Trusted proxy hops ────────────────────────────────────────────────────
# Number of trusted reverse proxies in front of the backend. Each one
# appends its observed connecting IP to X-Forwarded-For when forwarding,
# so we pick the entry at position -TRUSTED_PROXY_HOPS to land on the
# value the *first* trusted proxy saw. Default 1 matches the current
# prod topology (Railway → backend). Bump to 2 if Cloudflare or another
# trusted reverse proxy ever sits in front of Railway — the audit log
# IP otherwise reads as the immediate proxy, not the actual client.
#
# Important: never set this higher than the *actual* number of trusted
# proxies in front. When the XFF chain is shorter than N,
# _client_ip clamps to the left-most entry (better forensics
# than dropping the value entirely), but the left-most entry is what
# the original client wrote, which is attacker-controllable. An over-
# bumped hop count regresses the spoof-resistance the right-most-entry
# rule exists to provide.
# TRUSTED_PROXY_HOPS=1

# ── Transactional email ───────────────────────────────────────────────────
# `console` (default) just logs the email body — perfect for local dev so
# you don't burn Resend quota or chase DKIM. Switch to `resend` once the
# domain is verified in the Resend dashboard.
EMAIL_PROVIDER=console
# Required when EMAIL_PROVIDER=resend.
RESEND_API_KEY=
# `From:` address. Must match a domain you've verified with Resend.
EMAIL_FROM=noreply@vidit.app
EMAIL_FROM_NAME=Vidit
# Public origin of the frontend, used to build links in emails. No trailing
# slash. Locally points at the Next dev server; in prod the deploy workflow
# sets this to https://vidit.app.
FRONTEND_URL=http://localhost:3000
# Password-reset token TTL (minutes). Default: 15. Tighter values are
# safer; loosen at your own risk. Registration-confirmation TTL is
# hard-coded (24h) in services/registration.py.
# PASSWORD_RESET_TOKEN_MINUTES=15

# ── Admin role bootstrap ──────────────────────────────────────────────────
# Comma-separated allowlist. Every login/register checks the email against
# this list and flips ``is_admin=true`` on a match. Empty (the default for
# local dev) means nobody auto-promotes. In prod set to admin@vidit.app.
# ADMIN_EMAILS=admin@vidit.app

# ── X bot (the "tag @ViditBot" on-ramp) ───────────────────────────────────
# All empty locally: the bot runner (scripts/run_bot.py) refuses to start
# without the read pair, and the paid X API has no local-dev mode anyway.
# Reading mentions: the X app's app-only bearer token + the bot account's
# numeric user id (both from the X developer console). Set together.
X_BOT_BEARER_TOKEN=
X_BOT_USER_ID=
# Posting replies: OAuth 1.0a user context for the bot account. Set all
# four or none; without them the bot processes mentions but posts nothing.
X_API_CONSUMER_KEY=
X_API_CONSUMER_SECRET=
X_BOT_ACCESS_TOKEN=
X_BOT_ACCESS_TOKEN_SECRET=
