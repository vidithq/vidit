# Vision frontend environment variables
# Copy to frontend/.env.local for local development. Production values live in Vercel.

# Backend API base URL (must include the /api/v1 suffix).
# Local default talks to a uvicorn instance on :8000.
# Production: NEXT_PUBLIC_API_URL=https://<railway-domain>/api/v1
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Sentry — optional, leave unset locally. When set, the SDK boots in
# sentry.{client,server,edge}.config.ts and `app/error.tsx` /
# `app/global-error.tsx` forward caught exceptions. All four vars stay empty
# during the bootstrap phase before the Sentry project is provisioned —
# withSentryConfig and Sentry.init() both no-op gracefully.
# NEXT_PUBLIC_SENTRY_DSN=https://<key>@oXXXXX.ingest.sentry.io/<project>
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0
# Server / edge runtime — set on Vercel only, not in the client bundle:
# SENTRY_DSN, SENTRY_ENVIRONMENT, SENTRY_TRACES_SAMPLE_RATE
# Build-time (for source-map upload, set on Vercel + the deploy workflow):
# SENTRY_ORG, SENTRY_PROJECT, SENTRY_AUTH_TOKEN
